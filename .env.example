# ============================================================
# TECHPAGE AUTO — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── AI Content Generation ────────────────────────────────────
# Option A: Anthropic Claude (recommended — Haiku is cheapest)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Option B: Google Gemini (alternative — has free tier)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set AI_PROVIDER to "claude" or "gemini"
AI_PROVIDER=claude

# ── Instagram Graph API ──────────────────────────────────────
# Step 1: Create a Facebook Developer App at developers.facebook.com
# Step 2: Add Instagram Graph API product
# Step 3: Link your Instagram Business/Creator account to a Facebook Page
# Step 4: Generate a long-lived User Access Token (60-day expiry, needs refresh)
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=123456789012345
# Your Instagram username (shown on slide 5 CTA)
INSTAGRAM_HANDLE=nvhotech
# Your Facebook App credentials (needed for token refresh)
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fallback image if cover generation fails (public HTTPS URL, JPEG/PNG)
INSTAGRAM_DEFAULT_IMAGE_URL=https://example.com/your-default-card.jpg
# Max characters for IG caption (including hashtags); default 480, hard max 2200
INSTAGRAM_CAPTION_MAX_CHARS=480
# Optional: post pre-uploaded carousel slides only (scripts/post-carousel-from-urls.js)
# CAROUSEL_IMAGE_URLS=https://.../a.jpg,https://.../b.jpg
# CAROUSEL_CAPTION=

# ── Cover image generation ───────────────────────────────────
# pil    = local Python/PIL (free, text-card)
# openai = DALL-E 3 via OPENAI_API_KEY
# gemini = Google Imagen via GEMINI_API_KEY (often requires paid Google AI plan)
# If COVER_IMAGE_MODE is unset: OPENAI_API_KEY → openai; else GEMINI_API_KEY → gemini; else pil.
# When COVER_IMAGE_MODE=openai and ANTHROPIC_API_KEY is set: Claude drafts the DALL-E prompt
# (50/50 visual | typography) unless OPENAI_IMAGE_CLAUDE_PROMPT=false.
COVER_IMAGE_MODE=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=standard
# Use Claude to compose the DALL-E prompt (needs ANTHROPIC_API_KEY). Set false for static template only.
OPENAI_IMAGE_CLAUDE_PROMPT=true
# If DALL-E fails, fall back to PIL (set false to hard-fail)
OPENAI_IMAGE_FALLBACK_PIL=true
# Imagen (optional). If unset, tries imagen-4.0-generate-001 then fallbacks on 404.
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_ASPECT_RATIO=1:1
GEMINI_IMAGEN_FALLBACK_PIL=true

# ── Cloudflare R2 (cover images → public URL for Instagram) ───
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── LinkedIn API ─────────────────────────────────────────────
# Step 1: Create app at linkedin.com/developers
# Step 2: Request "Share on LinkedIn" + "Sign In with LinkedIn" products
# Step 3: Get OAuth2 token with w_member_social scope
# Step 4: Complete app review (takes 1–2 weeks for w_member_social)
LINKEDIN_ACCESS_TOKEN=AQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_PERSON_URN=urn:li:person:xxxxxxxx
# For company page posting (optional)
LINKEDIN_ORGANIZATION_URN=urn:li:organization:xxxxxxxx
# Set to "person" or "organization"
LINKEDIN_POST_AS=person

# ── Telegram Bot (approval system) ──────────────────────────
# Create a bot via @BotFather on Telegram
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
# If true, Approve only queues for cron / --publish (no instant Instagram/LinkedIn)
TELEGRAM_APPROVE_WITHOUT_PUBLISH=false

# ── App Config ───────────────────────────────────────────────
# How many stories to fetch per run
FETCH_LIMIT=10
# When ANTHROPIC_API_KEY is set: Claude ranks real web candidates (HN + RSS + Google News). Set false for score-only sort.
CLAUDE_TREND_PICK=true
# Optional override for Google News RSS (default: tech + AI + startups US feed)
GOOGLE_NEWS_RSS_URL=
# Minimum HN score to include a story
HN_MIN_SCORE=100
# Post schedule: cron format (default: 9am IST = 3:30am UTC)
POST_CRON=30 3 * * *
# Require Telegram approval before posting (true/false)
REQUIRE_APPROVAL=true
# Approval timeout in minutes (auto-skip if no response)
APPROVAL_TIMEOUT_MINUTES=30
# Which platforms to post to (comma-separated: instagram,linkedin)
PLATFORMS=instagram,linkedin
# Node environment
NODE_ENV=production
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ── Video Pipeline ───────────────────────────────────────────
# Enable video generation (carousel posts on other days, video on VIDEO_DAYS)
VIDEO_ENABLED=false
# Days of week to post video (0=Sun,1=Mon,...6=Sat). Comma-separated. e.g. "2,5" = Tue+Fri
VIDEO_DAYS=2,5

# ElevenLabs — text-to-speech
# Get API key at elevenlabs.io (free tier: 10k chars/mo)
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Voice ID to use. Default: Rachel (21m00Tcm4TlvDq8ikWAM) — or browse elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ElevenLabs model: eleven_monolingual_v1 (fast), eleven_multilingual_v2 (best quality)
ELEVENLABS_MODEL=eleven_monolingual_v1
# Target script duration in seconds (TTS output length is approximate)
VIDEO_SCRIPT_SECONDS=55

# fal.ai LatentSync — lip-sync video generation
# Get API key at fal.ai (pay-per-use; ~$0.05/video)
FAL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LatentSync model ID (do not change unless fal.ai updates it)
FAL_LIPSYNC_MODEL=fal-ai/latentsync

# Base video — short face/presenter clip to loop for lip-sync
# Record a 5-10 second video of yourself looking at camera, mouth slightly open
# Must be: MP4/MOV, 720p+, good lighting, minimal background motion
# Absolute path on your machine:
BASE_VIDEO_PATH=/Users/yourname/techpage/base-video.mp4
# Resolution to resize base video before lipsync (width:height). Leave blank for auto.
BASE_VIDEO_RESOLUTION=720:1280

# Video output directory (temp files; auto-cleaned after upload)
VIDEO_OUTPUT_DIR=./output/video

# Video caption / post settings
# Max chars for Instagram video caption
VIDEO_CAPTION_MAX_CHARS=480
# Instagram reel cover (optional public HTTPS image URL). Leave blank to use auto-thumb.
INSTAGRAM_REEL_COVER_URL=
